  footer p{ margin:0; font-size:13px; color:var(--text-soft); }
  .social{ display:flex; gap:14px; }
  .social a{ color:var(--text-soft); transition:.2s; }
  .social a:hover{ color:var(--accent); transform:translateY(-2px); }

  #top-progress{
    position:fixed; top:0; left:0; height:2.5px; background:linear-gradient(90deg,var(--accent),var(--gold));
