  [data-theme="dark"]{
    --bg:#0A0E14;
    --surface:#0F151E;
    --surface-2:#131A24;
    --text:#EAF0F8;
    --text-soft:#8B96A5;
    --border:#1E2732;
    --accent:#5B93FF;
    --accent-soft:#132038;
    --gold:#D9AE6A;
