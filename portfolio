    animation:pulse 2s infinite;
  }
  @keyframes pulse{ 0%{transform:scale(.6); opacity:.9;} 100%{transform:scale(1.8); opacity:0;} }

  .hero h1{ font-size:clamp(38px,5.4vw,60px); line-height:1.06; margin:0 0 20px; }
  .hero h1 span{ color:var(--accent); }
  .hero p.lead{ font-size:18px; line-height:1.75; color:var(--text-soft); max-width:560px; margin:0 0 34px; }
  .hero-actions{ display:flex; gap:12px; flex-wrap:wrap; margin-bottom:44px; }
  .meta-row{ display:flex; gap:26px; flex-wrap:wrap; }
  .meta-item{ display:flex; align-items:center; gap:8px; font-size:13.5px; color:var(--text-soft); }
  .meta-item svg{ flex-shrink:0; }

  .hero-card{
    background:var(--surface); border:1px solid var(--border); border-radius:20px;
