  .pipeline-track{ position:relative; height:6px; border-radius:6px; background:var(--surface-2); overflow:hidden; margin:18px 0 14px; }
  .pipeline-track .flow{
    position:absolute; top:0; left:-40%; width:40%; height:100%;
    background:linear-gradient(90deg, transparent, var(--accent), var(--gold), transparent);
